#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

PROG=/usr/bin/gateway_watchdog.sh
PIDFILE=/var/run/gateway_watchdog.pid
LOG_TAG="gateway_watchdog"

start_service() {
    local enabled
    config_load gateway_watchdog
    config_get_bool enabled settings enabled 1
    [ "$enabled" -eq 0 ] && return 0

    [ -x "$PROG" ] || {
        logger -t "$LOG_TAG" "Error: $PROG not found or not executable"
        return 1
    }

    procd_open_instance
    procd_set_param command "$PROG"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile "$PIDFILE"
    procd_close_instance
}

stop_service() {
    rm -f /tmp/gateway_watchdog_stats \
          /tmp/gateway_watchdog.history \
          /tmp/gateway_watchdog.history.lock \
          /tmp/gateway_watchdog.lock \
          2>/dev/null
}

service_triggers() {
    procd_add_reload_trigger "gateway_watchdog"
}
